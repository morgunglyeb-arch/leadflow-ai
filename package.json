{
  "name": "leadflow-ai",
  "version": "1.0.0",
  "private": true,
  "description": "Agentic TypeScript pipeline: enriches B2B leads from their websites and writes AI-personalized cold-outreach copy. Anthropic + Groq, tool-use + prompt caching, zod validation, anti-hallucination by design.",
  "type": "module",
  "keywords": [
    "agentic",
    "typescript",
    "nodejs",
    "claude",
    "anthropic",
    "groq",
    "llm",
    "prompt-caching",
    "tool-use",
    "zod",
    "lead-enrichment",
    "cold-outreach",
    "sdr",
    "personalization",
    "csv",
    "google-sheets",
    "resend",
    "no-n8n",
    "idempotent",
    "anti-hallucination"
  ],
  "author": "Glyeb Morgun <morgunglyeb@gmail.com>",
  "license": "MIT",
  "scripts": {
    "leads": "tsx src/index.ts",
    "prospect": "tsx src/cli-prospect.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "gen:demo": "tsx scripts/gen-demo.ts",
    "view": "tsx scripts/view-csv.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "dotenv": "^16.4.5",
    "googleapis": "^144.0.0",
    "openai": "^4.71.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
