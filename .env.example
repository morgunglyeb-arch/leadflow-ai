# --- LLM provider -------------------------------------------------------------
# "anthropic" (default) or "groq"
LLM_PROVIDER=anthropic

# Anthropic (Claude) — used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Groq — used when LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# --- What you're selling (used by the AI to score fit + write opener) --------
# Short, plain-English description of YOUR offer. The AI references this when
# rating fit_score and tailoring the icebreaker.
OUR_OFFER="AI automation for SMBs — we build agentic workflows that replace manual ops (lead enrichment, reporting, customer triage)."

# --- Leads source -------------------------------------------------------------
# "csv" (default) or "sheets"
LEADS_SOURCE=csv
LEADS_CSV_PATH=data/leads.csv

# Google Sheets (only when LEADS_SOURCE=sheets)
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_READ_RANGE=leads!A1:F
GOOGLE_SHEETS_WRITE_RANGE=leads_out!A1

# --- Enrichment -------------------------------------------------------------
ENRICH_TIMEOUT_MS=8000
ENRICH_USER_AGENT="LeadFlowAI/1.0 (+https://github.com/morgunglyeb-arch/leadflow-ai)"
ENRICH_CACHE_DIR=data/cache
CONCURRENCY=5

# --- Output ------------------------------------------------------------------
OUTPUT_CSV_PATH=data/out/leads_enriched.csv

# Optional: write enriched rows back to a Google Sheet tab
SHEETS_OUTPUT_ENABLED=false

# Optional: send a single test email through Resend with --send-test
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_TEST_TO=
