# --- LLM provider -------------------------------------------------------------
# "anthropic" (default) | "groq" | "openai" (any OpenAI-compatible endpoint)
LLM_PROVIDER=anthropic

# Anthropic (Claude) — used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Groq — used when LLM_PROVIDER=groq (fast, free tier is ~8k tokens/min)
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# Generic OpenAI-compatible provider — used when LLM_PROVIDER=openai.
# Plug in any free/cheap endpoint. Presets (uncomment one):
#   Google Gemini (generous free tier — best for volume):
#     OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#     OPENAI_MODEL=gemini-2.0-flash
#   Cerebras (very fast, free):
#     OPENAI_BASE_URL=https://api.cerebras.ai/v1
#     OPENAI_MODEL=llama-3.3-70b
#   OpenRouter (many free ":free" models):
#     OPENAI_BASE_URL=https://openrouter.ai/api/v1
#     OPENAI_MODEL=deepseek/deepseek-chat-v3-0324:free
OPENAI_API_KEY=
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_MODEL=gemini-2.0-flash

# Retry transient 429 rate-limits before falling back (honors "try again in Xs")
LLM_MAX_RETRIES=2

# --- What you're selling (used by the AI to score fit + write opener) --------
# Short, plain-English description of YOUR offer. The AI references this when
# rating fit_score and tailoring the icebreaker.
OUR_OFFER="We set up AI assistants for clinics & studios — instant missed-call text-back, 24/7 replies to web and Instagram/WhatsApp enquiries, appointment reminders and reactivation — so no booking is ever lost."

# --- Languages ---------------------------------------------------------------
# Language of the cold email sent TO the prospect (their language). en|uk|ru
OUTREACH_LANG=en
# Language of the per-lead analysis shown to YOU (problem + what to automate).
# This is what you read in the daily digest. ru|uk|en
DIGEST_LANG=ru

# --- Leads source -------------------------------------------------------------
# "csv" (default) or "sheets"
LEADS_SOURCE=csv
LEADS_CSV_PATH=data/leads.csv

# Google Sheets (only when LEADS_SOURCE=sheets)
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_READ_RANGE=leads!A1:F
GOOGLE_SHEETS_WRITE_RANGE=leads_out!A1

# --- Discovery (prospecting: `npm run prospect`) -----------------------------
# Where NEW leads come from: "search" (Serper) | "maps" (Google Places) | "vibe"
DISCOVERY_SOURCE=search
# Your ideal-customer profile + search queries (see config/icp.example.json)
ICP_CONFIG_PATH=config/icp.json
# Cap on total discovered leads per run (e.g. 50/day)
MAX_LEADS=50

# Web search discoverer (Serper.dev — cheap Google results API)
SEARCH_PROVIDER=serper
SERPER_API_KEY=

# Maps discoverer backend:
#   "serper" (default) — uses Serper /places, needs only SERPER_API_KEY,
#            resolves each business's website with one extra search.
#   "google" — Google Places API (New): richer (website+phone in one call),
#            but you must enable "Places API (New)" + billing in Google Cloud.
MAPS_PROVIDER=serper
GOOGLE_PLACES_API_KEY=

# Vibe Prospecting: the agent runs an MCP session and writes normalized
# vibe_*.json exports here; the pipeline reads them as a discovery source.
VIBE_EXPORT_DIR=data/discovered

# --- Enrichment -------------------------------------------------------------
ENRICH_TIMEOUT_MS=8000
ENRICH_USER_AGENT="LeadFlowAI/1.0 (+https://github.com/morgunglyeb-arch/leadflow-ai)"
ENRICH_CACHE_DIR=data/cache
CONCURRENCY=5

# --- Output ------------------------------------------------------------------
OUTPUT_CSV_PATH=data/out/leads_enriched.csv
# Draft email queue (one .md per lead + an index CSV) for human review
DRAFTS_DIR=data/out/drafts
DRAFTS_CSV_PATH=data/out/drafts.csv

# Sender identity baked into draft emails
SENDER_NAME=Glyeb                     # use a REAL person's first name (deliverability + reply rate)
SENDER_SIGNATURE="Opero · AI assistants for clinics & studios"
# NO calls — the sender doesn't take live calls. The only ask is an async reply / a short example.
CALL_TO_ACTION="Want a 30-second example of how it'd look for your clinic? Just reply."

# Optional: write enriched rows back to a Google Sheet tab
SHEETS_OUTPUT_ENABLED=false

# Draft queue + daily digest preview (rendered locally every run)
DRAFTS_DIR=data/out/drafts
DIGEST_HTML_PATH=data/out/digest.html

# Email delivery via Resend (for --send-test and the daily --digest)
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_TEST_TO=
# Your own inbox — where `npm run prospect -- --digest` sends the daily digest
# (RU analysis of each lead + the ready-to-send English drafts).
EMAIL_DIGEST_TO=

# --- Autonomous campaign (Gmail send + follow-up + learning) -----------------
# See docs/GMAIL_SETUP.md. Master safety switch — must be true to actually send.
SENDING_ENABLED=false
GMAIL_SENDER=                         # your authorized sending Gmail (the From:)
GMAIL_CREDENTIALS_PATH=secrets/gmail_credentials.json
GMAIL_TOKEN_PATH=secrets/gmail_token.json
CAMPAIGN_STATE_PATH=data/campaign/state.json
# The agent self-limits volume: min(warmup-today, leads above SEND_MIN_SCORE)
SEND_DAILY_CAP=25                     # safe cold ceiling per inbox (conservative; 40 risks reputation)
SEND_WARMUP_START=10                  # gentle day-1 volume (fresh inbox)
SEND_WARMUP_STEP=2                    # +N/day → full volume in ~3-4 weeks (the safe step)
SEND_MIN_SCORE=9                      # only send leads at/above this ROI score
SEND_PER_RUN_CAP=0                    # 0=off; >0 + hourly cron in SEND_WINDOW = spread volume (anti-burst)
FOLLOWUP_GAP_DAYS=3,10                # follow-up #1 at +3 days, #2 at +10
OPT_OUT_TEXT="Not relevant? Reply 'no' and I won't follow up."
SELF_CRITIQUE=true                    # second LLM pass that fixes weak drafts

# Compliance / deliverability gates (run unattended, code-enforced)
DELIVERABILITY_GATE=true              # skip inboxes whose domain fails SPF/DKIM/DMARC
SEND_CORPORATE_ONLY=true             # PECR: only auto-send to incorporated entities
REQUIRE_LTD=true                      # strengthen the above with the Companies House register
COMPANIES_HOUSE_API_KEY=             # optional — UK register lookup (free)

# --- Peer warmup (free, in-house — our inboxes email each other) --------------
# OFF by default. Needs the gmail.modify scope → re-auth all inboxes first.
WARMUP_ENABLED=false
WARMUP_DAILY=2                        # per-inbox volume, day 1
WARMUP_DAILY_MAX=8                    # per-inbox plateau (safe protocol: hold 5–8/day)
WARMUP_RAMP_DAYS=21                   # days to ramp DAILY → DAILY_MAX
WARMUP_REPLY_RATE=0.33               # fraction of received warmup mail we reply to (~human)
WARMUP_COLD_AFTER_DAYS=14            # hold cold first-touches until week 3

# --- Enrichment providers (all optional; pipeline degrades gracefully) ---------
FIRECRAWL_API_KEY=                    # JS-rendering crawler (cleaner markdown; falls back to built-in HTTP)
HUNTER_API_KEY=                       # email finder + SMTP-level verify (free: 25/mo)

# --- Opero Ops telemetry (optional) -------------------------------------------
# Emit run.start / run.end to the Opero Ops control plane. Best-effort: both
# must be set to enable; otherwise the emitter is a silent no-op.
OPERO_OPS_URL=                        # public URL of the Opero Ops app
INGEST_BEARER_TOKEN=                  # shared secret with Opero Ops /api/ingest/*
